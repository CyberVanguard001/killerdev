local function CriarBotaoKiller(nome, funcao)
    local btn = Instance.new("TextButton")
    btn.BackgroundColor3 = Color3.fromRGB(32, 22, 22)
    btn.Text = nome
    btn.TextColor3 = Color3.fromRGB(245, 215, 215)
    btn.TextSize = 12
    btn.Font = Enum.Font.SourceSans
    btn.Parent = PageKiller

    local BS = Instance.new("UIStroke")
    BS.Color = Color3.fromRGB(140, 35, 35)
    BS.Parent = btn
    
    local BC = Instance.new("UICorner")
    BC.CornerRadius = UDim.new(0, 4)
    BC.Parent = btn

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(48, 20, 20)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(32, 22, 22)}):Play()
    end)

    btn.MouseButton1Click:Connect(function() pcall(funcao) end)
end

