local function CriarBotaoKiller(nome, funcao)
    local btn = Instance.new("TextButton", PageKiller)
    -- Cor preta padrão para combinar com os interruptores
    btn.BackgroundColor3 = Color3.fromRGB(26, 26, 30) 
    btn.Text = nome
    btn.TextColor3 = Color3.fromRGB(235, 235, 235)
    btn.Font = Enum.Font.SourceSans
    local BS = Instance.new("UIStroke", btn)
    BS.Color = Color3.fromRGB(52, 52, 58)
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
 
    btn.MouseEnter:Connect(function() 
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(38, 32, 32)}):Play() 
        BS.Color = Color3.fromRGB(160, 30, 30)
    end)
    btn.MouseLeave:Connect(function() 
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(26, 26, 30)}):Play() 
        BS.Color = Color3.fromRGB(52, 52, 58)
    end)
    btn.MouseButton1Click:Connect(function() pcall(funcao) end)
end
 
local function CriarToggleKiller(nome, callback)
    local btn = Instance.new("TextButton", PageKiller)
    btn.BackgroundColor3 = Color3.fromRGB(26, 26, 30)
    btn.Text = ""
    Instance.new("UIStroke", btn).Color = Color3.fromRGB(52, 52, 58)
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
 
    local label = Instance.new("TextLabel", btn)
    label.Size = UDim2.new(0.65, 0, 1, 0)
    label.Position = UDim2.new(0, 8, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = nome
    label.TextColor3 = Color3.fromRGB(235, 235, 235)
    label.Font = Enum.Font.SourceSansBold
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
 
    local toggleBg = Instance.new("Frame", btn)
    toggleBg.Size = UDim2.new(0, 32, 0, 16)
    toggleBg.Position = UDim2.new(1, -38, 0.5, -8)
    toggleBg.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
    Instance.new("UICorner", toggleBg).CornerRadius = UDim.new(1, 0)
 
    local circle = Instance.new("Frame", toggleBg)
    circle.Size = UDim2.new(0, 12, 0, 12)
    circle.Position = UDim2.new(0, 2, 0.5, -6)
    circle.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)
 
    local estado = false
    btn.MouseButton1Click:Connect(function()
        estado = not estado
        local pos = estado and UDim2.new(1, -14, 0.5, -6) or UDim2.new(0, 2, 0.5, -6)
        local bgCor = estado and Color3.fromRGB(180, 40, 40) or Color3.fromRGB(40, 40, 45)
        local cCor = estado and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(200, 200, 200)
 
        TweenService:Create(circle, TweenInfo.new(0.2), {Position = pos, BackgroundColor3 = cCor}):Play()
        TweenService:Create(toggleBg, TweenInfo.new(0.2), {BackgroundColor3 = bgCor}):Play()
        callback(estado)
    end)
end
 
