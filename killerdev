local function startFly()
    flying = true
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end
    
    bodyVel = Instance.new("BodyVelocity")
    bodyVel.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bodyVel.Velocity = Vector3.zero
    bodyVel.Parent = hrp

    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bodyGyro.P = 9e4
    bodyGyro.CFrame = workspace.CurrentCamera.CFrame
    bodyGyro.Parent = hrp
    
    hum:ChangeState(Enum.HumanoidStateType.Physics)
    
    RunService:BindToRenderStep("KillerFlyLoop", Enum.RenderPriority.Camera.Value, function()
        if not flying or not char:FindFirstChild("Humanoid") then return end
        local cam = workspace.CurrentCamera
        
        bodyGyro.CFrame = cam.CFrame
        hum:ChangeState(Enum.HumanoidStateType.Physics)
        
        local moveDir = hum.MoveDirection
        local velocity = Vector3.zero
        
        if moveDir.Magnitude > 0 then
            
            local camFwd = Vector3.new(cam.CFrame.LookVector.X, 0, cam.CFrame.LookVector.Z).Unit
            local camRgt = Vector3.new(cam.CFrame.RightVector.X, 0, cam.CFrame.RightVector.Z).Unit
            
            local fwdIntent = moveDir:Dot(camFwd)
            local rgtIntent = moveDir:Dot(camRgt)
            
            velocity = (cam.CFrame.LookVector * fwdIntent) + (cam.CFrame.RightVector * rgtIntent)
        end
        
        if velocity.Magnitude > 0 then
            velocity = velocity.Unit * (flySpeed * 50)
        end
        
        -- Override vertical dos botões UP / DOWN da tela
        if flyUp then velocity = velocity + Vector3.new(0, flySpeed * 50, 0) end
        if flyDown then velocity = velocity + Vector3.new(0, -flySpeed * 50, 0) end
        
        bodyVel.Velocity = velocity
    end)
end

local function stopFly()
    flying = false
    RunService:UnbindFromRenderStep("KillerFlyLoop")
    if bodyVel then bodyVel:Destroy() end
    if bodyGyro then bodyGyro:Destroy() end
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
    end
end

